#!/bin/bash
# ============================================================
# filesystem-guard.sh — OpenClaw 文件系统安全防护
# 通过 POSIX ACL 和文件权限限制 Agent 对敏感目录的访问
# ============================================================

set -euo pipefail

echo "=== OpenClaw 文件系统安全加固 ==="
echo "时间: $(date '+%Y-%m-%d %H:%M:%S')"

# --- 1. 保护 /etc/shadow 和 /etc/passwd ---
echo "[1/5] 加固系统关键文件权限..."
chmod 600 /etc/shadow 2>/dev/null || true
chmod 644 /etc/passwd 2>/dev/null || true
# 设置不可变属性防止 Agent 修改
chattr +i /etc/passwd 2>/dev/null || echo "  注意: chattr 不可用，跳过不可变属性设置"
chattr +i /etc/shadow 2>/dev/null || echo "  注意: chattr 不可用，跳过不可变属性设置"
echo "  /etc/passwd 和 /etc/shadow 已加固"

# --- 2. 保护 .env 和配置文件中的敏感信息 ---
echo "[2/5] 保护 OpenClaw 敏感配置文件..."
chmod 600 /root/.openclaw/.env
chmod 600 /root/.openclaw/openclaw.json
chmod 600 /root/.openclaw/identity/device-auth.json 2>/dev/null || true
chmod 600 /root/.openclaw/identity/device.json 2>/dev/null || true
echo "  .env 和配置文件权限已收紧到 600"

# --- 3. 保护 SSH 密钥 ---
echo "[3/5] 保护 SSH 相关文件..."
chmod 700 /root/.ssh 2>/dev/null || true
chmod 600 /root/.ssh/* 2>/dev/null || true
echo "  SSH 目录权限已加固"

# --- 4. 创建安全审计日志目录 ---
echo "[4/5] 创建安全审计日志..."
AUDIT_DIR="/root/.openclaw/workspace/memory/security-audit"
mkdir -p "$AUDIT_DIR"
cat > "$AUDIT_DIR/README.md" << 'AUDIT_EOF'
# Security Audit Log

此目录记录安全相关事件。由 filesystem-guard.sh 创建。

## 文件说明
- `guard-runs.log` — 安全加固脚本执行记录
- `access-violations.log` — 访问违规记录（由 inotify 监控生成）
AUDIT_EOF

echo "$(date '+%Y-%m-%d %H:%M:%S') - filesystem-guard.sh executed successfully" >> "$AUDIT_DIR/guard-runs.log"
echo "  审计日志目录已创建: $AUDIT_DIR"

# --- 5. 创建路径白名单配置文件 ---
echo "[5/5] 创建路径白名单配置..."
cat > /root/.openclaw/workspace/SECURITY.md << 'SECURITY_EOF'
# SECURITY.md — 安全规则（硬性约束）

> **此文件定义了不可违反的安全边界。任何 Agent 在执行文件操作前必须检查此文件。**

## 禁止访问的路径（黑名单）

以下路径**绝对禁止**读取、写入或执行：

| 路径 | 原因 |
|------|------|
| `/etc/shadow` | 系统密码哈希，极度敏感 |
| `/etc/passwd`（写入） | 系统用户数据库，禁止修改 |
| `/etc/sudoers` | sudo 权限配置 |
| `/root/.ssh/` | SSH 密钥和配置 |
| `/root/.openclaw/.env` | API 密钥和令牌 |
| `/root/.openclaw/openclaw.json` | 系统主配置（含凭证引用） |
| `/root/.openclaw/identity/` | 设备认证信息 |
| `/proc/`, `/sys/` | 内核接口 |

## 允许访问的路径（白名单）

Agent 仅允许在以下路径范围内操作：

| 路径 | 权限 | 说明 |
|------|------|------|
| `/root/.openclaw/workspace/` | 读写 | 主工作区 |
| `/root/.openclaw/workspace-coding/` | 读写 | 编码工作区 |
| `/root/.openclaw/workspace-researcher/` | 读写 | 研究工作区 |
| `/tmp/` | 读写 | 临时文件 |
| `/root/.openclaw/media/` | 读写 | 媒体文件 |

## 禁止执行的危险命令

以下命令模式**绝对禁止**执行：

- `rm -rf /` 或任何针对根目录的递归删除
- `:(){ :|:& };:` （Fork 炸弹）
- `chmod 777` 对系统目录
- `curl | bash` 或 `wget | sh` （远程代码执行）
- `dd if=/dev/zero of=/dev/` （磁盘擦除）
- 任何修改 systemd 服务的命令（除非用户明确授权）

## 敏感信息保护

- **禁止**在回复中输出任何 API Key、Token、密码或密钥
- **禁止**读取 `.env` 文件并展示其内容
- **禁止**将配置文件中的凭证信息发送到任何外部渠道
- 如用户要求查看配置，只展示结构，不展示值

## 违规处理

任何违反上述规则的操作将被记录到 `memory/security-audit/access-violations.log`。
SECURITY_EOF

echo "  SECURITY.md 已创建"
echo ""
echo "=== 文件系统安全加固完成 ==="
