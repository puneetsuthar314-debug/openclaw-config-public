{
  "version": 1,
  "socket": {
    "path": "/root/.openclaw/exec-approvals.sock",
    "token": "<YOUR_TOKEN>"
  },
  "defaults": {
    "bash": {
      "mode": "ask",
      "comment": "Shell命令默认需要确认"
    }
  },
  "agents": {
    "main": {
      "tools": {
        "web_search": {
          "mode": "allow"
        },
        "web_fetch": {
          "mode": "allow"
        },
        "aliyun_web_search": {
          "mode": "allow"
        },
        "aliyun_web_parser": {
          "mode": "allow"
        },
        "read_file": {
          "mode": "allow"
        },
        "list_directory": {
          "mode": "allow"
        },
        "write_file": {
          "mode": "allow",
          "conditions": {
            "path_prefix": "/root/.openclaw/workspace"
          }
        }
      }
    }
  }
}