{"type":"message","id":"cd694cfb","parentId":"5b64dafa","timestamp":"2026-03-11T09:37:42.312Z","message":{"role":"toolResult","toolCallId":"call_165cb57082324e51b9f6c59f","toolName":"read","content":[{"type":"text","text":"/**\n * DingTalk reply implementation via sessionWebhook.\n */\nimport { chunkText, chunkMarkdownText, normalizeForTextMessage } from \"./chunker.js\";\nimport { convertMarkdownForDingTalk } from \"./markdown.js\";\nimport { deriveMarkdownTitle } from \"./markdown-title.js\";\n/**\n * Mask webhook URL for logging (hide query params).\n */\nfunction maskWebhook(url) {\n    if (!url)\n        return \"\";\n    try {\n        const u = new URL(url);\n        return `${u.origin}${u.pathname}`;\n    }\n    catch {\n        return String(url).slice(0, 64) + \"...\";\n    }\n}\nasync function readDingTalkWebhookResult(resp) {\n    const anyResp = resp;\n    // Prefer resp.text() when available because it works for both JSON and plain text.\n    if (typeof anyResp?.text === \"function\") {\n        const rawText = await anyResp.text();\n        if (!rawText?.trim()) {\n            return { rawText: \"\", data: undefined, recognized: false };\n        }\n        try {\n            const parsed = JSON.parse(rawText);\n            return { rawText, data: parsed, recognized: true };\n        }\n        catch {\n            return { rawText, data: undefined, recognized: false };\n        }\n    }\n    // Some tests mock fetch responses with json() only.\n    if (typeof anyResp?.json === \"function\") {\n        try {\n            const parsed = (await anyResp.json());\n            return { rawText: JSON.stringify(parsed ?? {}), data: parsed, recognized: true };\n        }\n        catch {\n            return { rawText: \"\", data: undefined, recognized: false };\n        }\n    }\n    return { rawText: \"\", data: undefined, recognized: false };\n}\nfunction isDingTalkWebhookOk(data, recognized) {\n    if (!recognized)\n        return false;\n    if (!data)\n        return true;\n    if (data.errcode === undefined)\n        return true;\n    return data.errcode === 0;\n}\n/**\n * Build the `at` block for a DingTalk webhook payload.\n */\nexport function buildAtBlock(at) {\n    const block = {};\n    if (at.atUserIds?.length)\n        block.atUserIds = at.atUserIds;\n    if (at.atMobiles?.length)\n        block.atMobiles = at.atMobiles;\n    if (at.isAtAll)\n        block.isAtAll = true;\n    return block;\n}\n/**\n * Append @userId text to message content so DingTalk highlights the mention.\n * Only appends user IDs (not mobiles) because DingTalk requires `@userId` in text.\n */\nexport function injectAtTextSuffix(content, at) {\n    const ids = at.atUserIds;\n    if (!ids?.length && !at.isAtAll)\n        return content;\n    if (at.isAtAll)\n        return `${content}\\n@所有人`;\n    return `${content}\\n${ids.map((id) => `@${id}`).join(\" \")}`;\n}\n/**\n * Send reply to DingTalk via sessionWebhook.\n * Automatically chunks long messages.\n */\nexport async function sendReplyViaSessionWebhook(sessionWebhook, text, options = {}) {\n    const { replyMode = \"text\", maxChars = 1800, tableMode = \"code\", logger, at } = options;\n    if (!sessionWebhook) {\n        logger?.warn?.(\"No sessionWebhook, cannot reply\");\n        return { ok: false, reason: \"missing_sessionWebhook\" };\n    }\n    let processedText = text;\n    if (replyMode === \"markdown\") {\n        processedText = convertMarkdownForDingTalk(processedText, { tableMode });\n    }\n    const cleaned = normalizeForTextMessage(processedText);\n    const chunks = replyMode === \"markdown\"\n        ? chunkMarkdownText(cleaned, maxChars)\n        : chunkText(cleaned, maxChars);\n    for (let i = 0; i < chunks.length; i++) {\n        const part = chunks[i];\n        const isFirstChunk = i === 0;\n        const atBlock = isFirstChunk && at ? buildAtBlock(at) : undefined;\n        const payload = replyMode === \"markdown\"\n            ? {\n                msgtype: \"markdown\",\n                markdown: {\n                    // DingTalk iOS push preview often uses the title field.\n                    title: deriveMarkdownTitle(part),\n                    text: isFirstChunk && at ? injectAtTextSuffix(part, at) : part,\n                },\n                ...(atBlock && Object.keys(atBlock).length > 0 ? { at: atBlock } : {}),\n            }\n            : {\n                msgtype: \"text\",\n                text: {\n                    content: isFirstChunk && at ? injectAtTextSuffix(part, at) : part,\n                },\n                ...(atBlock && Object.keys(atBlock).length > 0 ? { at: atBlock } : {}),\n            };\n        try {\n            const resp = await fetch(sessionWebhook, {\n                method: \"POST\",\n                headers: { \"Content-Type\": \"application/json\" },\n                body: JSON.stringify(payload),\n                signal: AbortSignal.timeout(30_000),\n            });\n            const parsed = await readDingTalkWebhookResult(resp);\n            if (!resp.ok) {\n                logger?.error?.({ err: { message: `HTTP ${resp.status}`, status: resp.status, data: parsed.rawText }, webhook: maskWebhook(sessionWebhook) }, \"Failed to reply DingTalk\");\n                return { ok: false, reason: \"http_error\", status: resp.status, data: parsed.rawText || parsed.data };\n            }\n            if (!isDingTalkWebhookOk(parsed.data, parsed.recognized)) {\n                logger?.error?.({\n                    errcode: parsed.data?.errcode,\n                    errmsg: parsed.data?.errmsg,\n                    response: parsed.rawText?.slice(0, 300),\n                    webhook: maskWebhook(sessionWebhook),\n                }, \"DingTalk API returned error for text reply\");\n                return { ok: false, reason: \"api_error\", status: resp.status, data: parsed.data ?? parsed.rawText };\n            }\n            logger?.debug?.({ webhook: maskWebhook(sessionWebhook), idx: i + 1, total: chunks.length }, \"Replied to DingTalk\");\n        }\n        catch (err) {\n            const error = err;\n            logger?.error?.({ err: { message: error?.message }, webhook: maskWebhook(sessionWebhook) }, \"Failed to reply DingTalk\");\n            return { ok: false, reason: \"fetch_error\" };\n        }\n    }\n    return { ok: true, chunks: chunks.length };\n}\n/**\n * Send an image reply via sessionWebhook.\n */\nexport async function sendImageViaSessionWebhook(sessionWebhook, picUrl, options = {}) {\n    const { text, logger } = options;\n    if (!sessionWebhook) {\n        logger?.warn?.(\"No sessionWebhook, cannot reply\");\n        return { ok: false, reason: \"missing_sessionWebhook\" };\n    }\n    // DingTalk sessionWebhook uses \"image\" msgtype with picURL\n    const payload = {\n        msgtype: \"image\",\n        image: {\n            picURL: picUrl,\n        },\n    };\n    try {\n        const resp = await fetch(sessionWebhook, {\n            method: \"POST\",\n            headers: { \"Content-Type\": \"application/json\" },\n            body: JSON.stringify(payload),\n            signal: AbortSignal.timeout(30_000),\n        });\n        const parsed = await readDingTalkWebhookResult(resp);\n        if (!resp.ok) {\n            logger?.error?.({ err: { message: `HTTP ${resp.status}`, status: resp.status, data: parsed.rawText }, webhook: maskWebhook(sessionWebhook) }, \"Failed to send image to DingTalk\");\n            return { ok: false, reason: \"http_error\", status: resp.status, data: parsed.rawText || parsed.data };\n        }\n        if (!isDingTalkWebhookOk(parsed.data, parsed.recognized)) {\n            logger?.error?.({\n                errcode: parsed.data?.errcode,\n                errmsg: parsed.data?.errmsg,\n                response: parsed.rawText?.slice(0, 300),\n                webhook: maskWebhook(sessionWebhook),\n            }, \"DingTalk API returned error for image send\");\n            return { ok: false, reason: \"api_error\", status: resp.status, data: parsed.data ?? parsed.rawText };\n        }\n        logger?.debug?.({ webhook: maskWebhook(sessionWebhook), picUrl }, \"Sent image to DingTalk\");\n        // If there's accompanying text, send it after the image\n        if (text?.trim()) {\n            await sendReplyViaSessionWebhook(sessionWebhook, text, { logger });\n        }\n        return { ok: true };\n    }\n    catch (err) {\n        const error = err;\n        logger?.error?.({ err: { message: error?.message }, webhook: maskWebhook(sessionWebhook) }, \"Failed to send image to DingTalk\");\n        return { ok: false, reason: \"fetch_error\" };\n    }\n}\n/**\n * Send an image reply via sessionWebhook using mediaId.\n * Use this when you have uploaded a file and have a mediaId.\n */\nexport async function sendImageWithMediaIdViaSessionWebhook(sessionWebhook, mediaId, options = {}) {\n    const { text, logger } = options;\n    if (!sessionWebhook) {\n        logger?.warn?.(\"No sessionWebhook, cannot reply\");\n        return { ok: false, reason: \"missing_sessionWebhook\" };\n    }\n    // DingTalk sessionWebhook uses \"image\" msgtype with media_id\n    const payload = {\n        msgtype: \"image\",\n        image: {\n            media_id: mediaId,\n        },\n    };\n    try {\n        const resp = await fetch(sessionWebhook, {\n            method: \"POST\",\n            headers: { \"Content-Type\": \"application/json\" },\n            body: JSON.stringify(payload),\n            signal: AbortSignal.timeout(30_000),\n        });\n        const parsed = await readDingTalkWebhookResult(resp);\n        if (!resp.ok) {\n            logger?.error?.({ err: { message: `HTTP ${resp.status}`, status: resp.status, data: parsed.rawText.slice(0, 500) }, webhook: maskWebhook(sessionWebhook) }, \"Failed to send image (mediaId) to DingTalk\");\n            return { ok: false, reason: \"http_error\", status: resp.status, data: parsed.rawText || parsed.data };\n        }\n        // Check DingTalk API-level error (HTTP 200 but errcode != 0)\n        if (!isDingTalkWebhookOk(parsed.data, parsed.recognized)) {\n            logger?.error?.({\n                errcode: parsed.data?.errcode,\n                errmsg: parsed.data?.errmsg,\n                response: parsed.rawText?.slice(0, 300),\n                webhook: maskWebhook(sessionWebhook),\n                mediaId,\n            }, \"DingTalk API returned error for image send\");\n            return { ok: false, reason: \"api_error\", status: resp.status, data: parsed.data ?? parsed.rawText };\n        }\n        logger?.debug?.({ webhook: maskWebhook(sessionWebhook), mediaId, response: parsed.rawText.slice(0, 200) }, \"Sent image (mediaId) to DingTalk\");\n        // If there's accompanying text, send it after the image\n        if (text?.trim()) {\n            await sendReplyViaSessionWebhook(sessionWebhook, text, { logger });\n        }\n        return { ok: true };\n    }\n    catch (err) {\n        const error = err;\n        logger?.error?.({ err: { message: error?.message }, webhook: maskWebhook(sessionWebhook) }, \"Failed to send image (mediaId) to DingTalk\");\n        return { ok: false, reason: \"fetch_error\" };\n    }\n}\n/**\n * Send an ActionCard reply via sessionWebhook.\n */\nexport async function sendActionCardViaSessionWebhook(sessionWebhook, actionCard, options = {}) {\n    const { logger, at } = options;\n    if (!sessionWebhook) {\n        logger?.warn?.(\"No sessionWebhook, cannot reply\");\n        return { ok: false, reason: \"missing_sessionWebhook\" };\n    }\n    // Build ActionCard payload for sessionWebhook\n    // DingTalk sessionWebhook uses different format than proactive API\n    let payload;\n    if (actionCard.buttons && actionCard.buttons.length >= 2) {\n        // Multi-button ActionCard\n        payload = {\n            msgtype: \"actionCard\",\n            actionCard: {\n                title: actionCard.title,\n                text: at ? injectAtTextSuffix(actionCard.text, at) : actionCard.text,\n                btnOrientation: actionCard.btnOrientation ?? \"0\",\n                btns: actionCard.buttons.map((btn) => ({\n                    title: btn.title,\n                    actionURL: btn.actionURL,\n                })),\n            },\n        };\n    }\n    else {\n        // Single-button ActionCard\n        payload = {\n            msgtype: \"actionCard\",\n            actionCard: {\n                title: actionCard.title,\n                text: at ? injectAtTextSuffix(actionCard.text, at) : actionCard.text,\n                singleTitle: actionCard.singleTitle ?? \"查看详情\",\n                singleURL: actionCard.singleURL ?? \"\",\n            },\n        };\n    }\n    if (at) {\n        const atBlock = buildAtBlock(at);\n        if (Object.keys(atBlock).length > 0) {\n            payload.at = atBlock;\n        }\n    }\n    try {\n        const resp = await fetch(sessionWebhook, {\n            method: \"POST\",\n            headers: { \"Content-Type\": \"application/json\" },\n            body: JSON.stringify(payload),\n            signal: AbortSignal.timeout(30_000),\n        });\n        const parsed = await readDingTalkWebhookResult(resp);\n        if (!resp.ok) {\n            logger?.error?.({ err: { message: `HTTP ${resp.status}`, status: resp.status, data: parsed.rawText }, webhook: maskWebhook(sessionWebhook) }, \"Failed to send ActionCard to DingTalk\");\n            return { ok: false, reason: \"http_error\", status: resp.status, data: parsed.rawText || parsed.data };\n        }\n        if (!isDingTalkWebhookOk(parsed.data, parsed.recognized)) {\n            logger?.error?.({\n                errcode: parsed.data?.errcode,\n                errmsg: parsed.data?.errmsg,\n                response: parsed.rawText?.slice(0, 300),\n                webhook: maskWebhook(sessionWebhook),\n            }, \"DingTalk API returned error for ActionCard send\");\n            return { ok: false, reason: \"api_error\", status: resp.status, data: parsed.data ?? parsed.rawText };\n        }\n        logger?.debug?.({ webhook: maskWebhook(sessionWebhook), title: actionCard.title }, \"Sent ActionCard to DingTalk\");\n        return { ok: true };\n    }\n    catch (err) {\n        const error = err;\n        logger?.error?.({ err: { message: error?.message }, webhook: maskWebhook(sessionWebhook) }, \"Failed to send ActionCard to DingTalk\");\n        return { ok: false, reason: \"fetch_error\" };\n    }\n}\n/**\n * Response prefix template variable pattern.\n */\nconst TEMPLATE_VAR_PATTERN = /\\{([a-zA-Z][a-zA-Z0-9.]*)\\}/g;\n/**\n * Resolve response prefix template with model context.\n */\nexport function resolveResponsePrefix(template, context) {\n    if (template === undefined || template === null)\n        return undefined;\n    return template.replace(TEMPLATE_VAR_PATTERN, (match, varName) => {\n        const normalized = varName.toLowerCase();\n        switch (normalized) {\n            case \"model\":\n                return context.model ?? match;\n            case \"provider\":\n                return context.provider ?? match;\n            case \"identity\":\n                return context.identity ?? match;\n            default:\n                return match;\n        }\n    });\n}\n//# sourceMappingURL=reply.js.map"}],"isError":false,"timestamp":1773221862297}}
{"type":"message","id":"98d565db","parentId":"cd694cfb","timestamp":"2026-03-11T09:38:16.426Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在我已经理解了整个消息流程。让我总结一下问题并给出完整的优化方案。\n\n关键发现：\n1. `message-parser.js` 已经提取了图片和文件的 downloadCode/picUrl\n2. 但是这些附件信息没有被传递给 OpenClaw 的 inbound 消息格式\n3. 即使有 downloadCode，也没有自动下载文件到本地的逻辑\n4. 钉钉 API 需要通过 downloadCode 调用下载接口获取文件内容\n\n现在我需要给出一个完整的优化方案。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"主人，已完成全网搜索和代码分析。以下是完整的优化方案：\n\n---\n\n# 钉钉附件接收优化方案\n\n## 问题根因\n\n**现状**：`clawdbot-dingtalk` 渠道的消息解析器已提取图片/文件的 `downloadCode` 和 `picUrl`，但：\n\n1. ❌ 附件信息**没有传递**给 OpenClaw 的 inbound 消息\n2. ❌ 没有**自动下载**附件到本地的逻辑\n3. ❌ 我无法通过 `image` 工具分析群里的图片\n\n---\n\n## 技术方案对比\n\n| 方案 | 实现位置 | 工作量 | 稳定性 | 推荐度 |\n|------|---------|--------|--------|--------|\n| **A. 渠道适配器改造** | `clawdbot-dingtalk` 插件 | 中等 | ⭐⭐⭐⭐⭐ | **强烈推荐** |\n| B. 浏览器自动化 | 独立脚本 | 高 | ⭐⭐ | 不推荐 |\n| C. 手动中转 | 用户操作 | 低 | ⭐⭐⭐ | 临时方案 |\n\n---\n\n## 推荐方案：A（渠道适配器改造）\n\n### 核心思路\n\n在 `clawdbot-dingtalk` 插件中实现：\n1. 收到图片/文件消息 → 调用钉钉 API 下载 → 保存到本地\n2. 将本地路径添加到 inbound 消息的 `attachments` 字段\n3. 我自动通过 `image` 工具分析\n\n### 修改文件清单\n\n```\n/usr/lib/node_modules/clawdbot-dingtalk/dist/src/\n├── monitor.js          # 主消息处理逻辑（修改）\n├── stream/\n│   └── message-parser.js  # 消息解析（已有 downloadCode 提取）\n├── api/\n│   ├── media.js        # 媒体下载（已有基础函数）\n│   └── media-upload.js # 媒体上传（参考）\n└── send/\n    └── reply.js        # 回复发送（参考）\n```\n\n### 实现步骤\n\n#### 第 1 步：增强消息解析器\n\n在 `message-parser.js` 中已提取的字段：\n```javascript\nconst downloadCode = \"xxxxx\"  // 文件下载码\nconst picUrl = \"https://...\"  // 图片 URL（有时效性）\nconst fileName = \"example.png\"\nconst fileType = \"image\"\n```\n\n#### 第 2 步：添加附件下载逻辑\n\n在 `monitor.js` 的消息接收入口处添加：\n\n```javascript\n// 当收到图片/文件消息时\nif (chat.downloadCode || chat.picUrl) {\n  const localPath = await downloadAttachment({\n    downloadCode: chat.downloadCode,\n    picUrl: chat.picUrl,\n    fileName: chat.fileName,\n    saveDir: '/root/.openclaw/workspace/attachments/',\n    tokenManager: tokenManager,\n  });\n  \n  // 将附件路径添加到 inbound 消息\n  ctx.attachments = [{\n    type: chat.fileType || 'image',\n    path: localPath,\n  }];\n}\n```\n\n#### 第 3 步：调用钉钉下载 API\n\n使用钉钉官方接口下载文件：\n\n```javascript\n// 图片：直接下载 picURL\n// 文件：通过 downloadCode 调用 API 获取下载链接\nGET https://api.dingtalk.com/v1.0/robot/messageFiles/download?downloadCode=xxx\n```\n\n#### 第 4 步：传递附件给 OpenClaw\n\n修改 inbound 消息构建逻辑，添加 `attachments` 字段：\n\n```javascript\nconst ctx = {\n  Body: chat.text || '',\n  RawBody: chat.text || '',\n  attachments: downloadedAttachments,  // 新增\n  // ...其他字段\n};\n```\n\n#### 第 5 步：测试验证\n\n1. 在钉钉群发送测试图片\n2. 确认我能看到并分析\n3. 发送测试文件（PDF/Word）\n4. 确认文件正确下载\n\n---\n\n## 代码修改量估算\n\n| 文件 | 修改行数 | 难度 |\n|------|---------|------|\n| `monitor.js` | +80~120 行 | 中等 |\n| `message-parser.js` | +20 行（可选增强） | 低 |\n| `api/media.js` | +50 行（下载函数） | 中等 |\n| **合计** | **~150~200 行** | **1-2 小时** |\n\n---\n\n## 临时方案（立即可用）\n\n在方案 A 实现前，可用以下方式：\n\n### 方案 C1：手动保存\n```bash\n# 用户保存图片到\n/root/.openclaw/workspace/images/temp.png\n\n# 然后告诉我\n\"看 images/temp.png\"\n```\n\n### 方案 C2：使用 image_search.py 脚本\n```bash\n# 如果图片来自公开 URL\n/root/anaconda3/bin/python3 /usr/local/bin/image_search.py \"关键词\" --limit 1 --output /root/.openclaw/workspace/images\n```\n\n---\n\n## 风险与注意事项\n\n| 风险点 | 应对措施 |\n|--------|---------|\n| 钉钉 API 鉴权失败 | 检查 clientId/clientSecret 配置 |\n| 图片 URL 过期 | 优先使用 downloadCode 接口 |\n| 大文件下载超时 | 设置 30 秒超时，失败时降级 |\n| 磁盘空间不足 | 定期清理 attachments 目录 |\n\n---\n\n## 执行建议\n\n**推荐顺序**：\n1. ✅ **立即执行方案 A** — 我帮你修改 `clawdbot-dingtalk` 代码\n2. ⏸️ 方案 C 作为临时备用\n\n---\n\n主人，你想让我：\n1. **立即开始修改代码** — 我现在去实现方案 A\n2. **先看详细设计文档** — 我生成更详细的伪代码\n3. **其他想法** — 你有补充需求\n\n选一个，我马上执行！🔧"}],"api":"openai-completions","provider":"dashscope","model":"qwen3.5-plus","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1773221862313}}
