{"type":"message","id":"d60ae38a","parentId":"a0437491","timestamp":"2026-03-10T07:59:17.358Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"python-docx 已安装完成。现在创建 Word 文档。\n","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_1adf8494d5e547ddaabedd3f","name":"exec","arguments":{"command":"/root/anaconda3/bin/python3 << 'PYTHON_SCRIPT'\nfrom docx import Document\nfrom docx.shared import Pt, RGBColor, Inches\nfrom docx.enum.text import WD_ALIGN_PARAGRAPH\nfrom docx.enum.style import WD_STYLE_TYPE\n\n# 创建文档\ndoc = Document()\n\n# 设置标题样式\ntitle = doc.add_heading('洲际油气 (600759) 深度研究报告', 0)\ntitle.alignment = WD_ALIGN_PARAGRAPH.CENTER\n\n# 添加副标题\nsubtitle = doc.add_paragraph('深度研究 · 投资决策参考')\nsubtitle.alignment = WD_ALIGN_PARAGRAPH.CENTER\nsubtitle.runs[0].italic = True\n\n# 添加日期\ndoc.add_paragraph('报告日期：2026 年 3 月 10 日')\ndoc.add_paragraph('分析模型：qwen3-max-2026-01-23')\n\n# 核心结论\ndoc.add_heading('📌 核心结论', level=1)\np = doc.add_paragraph()\np.add_run('短期：').bold = True\np.add_run('高风险规避 | ')\np.add_run('中期：').bold = True\np.add_run('观望等待 | ')\np.add_run('长期：').bold = True\np.add_run('资产价值有支撑，但需验证兑现能力')\n\ndoc.add_paragraph('当前股价已严重透支预期，主力资金出逃 + 业绩大幅下滑 + 估值泡沫三重压力下，短期回调风险极高。但公司核心资产质量优质，若伊拉克项目和氦气项目顺利投产，2027 年存在价值重估机会。')\n\n# 核心竞争力\ndoc.add_heading('🔬 一、核心竞争力分析（三张王牌）', level=1)\n\ndoc.add_heading('王牌 1：哈萨克斯坦低成本油田（现金流基石）', level=2)\ntable = doc.add_table(rows=5, cols=3)\ntable.style = 'Table Grid'\nheaders = ['指标', '数据', '行业对比']\nfor i, h in enumerate(headers):\n    table.rows[0].cells[i].text = h\n    table.rows[0].cells[i].paragraphs[0].runs[0].bold = True\n\ndata1 = [\n    ['马腾油田探明储量', '1.07 亿桶', '-'],\n    ['克山油田探明储量', '1.11 亿桶', '-'],\n    ['操作成本', '6-10 美元/桶', '行业平均 30-40 美元'],\n    ['采收率', '42%', '行业平均 34%'],\n]\nfor i, row in enumerate(data1):\n    for j, cell in enumerate(row):\n        table.rows[i+1].cells[j].text = cell\n\ndoc.add_paragraph('关键洞察：只要油价维持在 60 美元以上，公司就能盈利。这是公司穿越周期的核心护城河。')\n\ndoc.add_heading('王牌 2：伊拉克高增长项目（2027 年投产）', level=2)\ndoc.add_paragraph('• 南巴士拉项目：地质储量 80 亿桶，规划产能 10 万桶/日')\ndoc.add_paragraph('• 配套炼油厂 20 万桶/日 + 650MW 电厂')\ndoc.add_paragraph('• 总投资 12.66 亿美元，公司持股 67%')\ndoc.add_paragraph('• 2027 年达产后，业绩有望翻倍')\n\ndoc.add_heading('王牌 3：苏克气田氦气资源（战略稀缺性）', level=2)\ndoc.add_paragraph('• 氦气可采储量：13.01 亿立方米')\ndoc.add_paragraph('• 相当于中国已探明总量的 118%')\ndoc.add_paragraph('• 2027 年投产，年产能 1000 万立方米')\ndoc.add_paragraph('• 客户锁定中芯国际等，年收益预计 5.25 亿元')\ndoc.add_paragraph('• 氦气是\"卡脖子\"战略资源，价格刚性强')\n\n# 财务分析\ndoc.add_heading('📉 二、财务健康度分析', level=1)\n\ndoc.add_heading('债务重整效果显著', level=2)\ntable2 = doc.add_table(rows=4, cols=4)\ntable2.style = 'Table Grid'\nheaders2 = ['指标', '2022 年末', '2025 年 Q3', '变化']\nfor i, h in enumerate(headers2):\n    table2.rows[0].cells[i].text = h\n    table2.rows[0].cells[i].paragraphs[0].runs[0].bold = True\n\ndata2 = [\n    ['资产负债率', '69.21%', '28.74%', '-40.47pct'],\n    ['财务费用', '4.24 亿元', '0.88 亿元', '-79.26%'],\n    ['债务清偿', '-', '76 亿元', '境内债务基本清偿'],\n]\nfor i, row in enumerate(data2):\n    for j, cell in enumerate(row):\n        table2.rows[i+1].cells[j].text = cell\n\ndoc.add_heading('但业绩承压明显', level=2)\ntable3 = doc.add_table(rows=4, cols=5)\ntable3.style = 'Table Grid'\nheaders3 = ['报告期', '营收', '同比', '净利润', '同比']\nfor i, h in enumerate(headers3):\n    table3.rows[0].cells[i].text = h\n    table3.rows[0].cells[i].paragraphs[0].runs[0].bold = True\n\ndata3 = [\n    ['2025 年 Q1-Q3', '15.37 亿', '-19.94%', '8308 万', '-46.61%'],\n    ['2024 年全年', '25.48 亿', '-6.56%', '4.88 亿', '-61.61%'],\n    ['2025 年全年（预告）', '-', '-', '1.05-1.5 亿', '-78% 至 -69%'],\n]\nfor i, row in enumerate(data3):\n    for j, cell in enumerate(row):\n        table3.rows[i+1].cells[j].text = cell\n\n# 风险因素\ndoc.add_heading('⚠️ 三、风险因素深度剖析', level=1)\n\nrisks = [\n    ('风险 1：估值泡沫严重', '当前市盈率 (TTM) 74.87 倍，油气行业平均约 15-20 倍'),\n    ('风险 2：主力资金持续出逃', '3 月 10 日主力净流出 8.50 亿元，近 5 天累计净流出 19.07 亿元'),\n    ('风险 3：股东违规被立案', '2025 年 11 月，股东海口东铎违规增持被证监会立案'),\n    ('风险 4：国际油价不确定性', '2026 年布伦特油价预测中枢 55-75 美元/桶'),\n    ('风险 5：项目投产延期风险', '伊拉克项目 2027 年投产是业绩拐点关键'),\n]\nfor title, content in risks:\n    p = doc.add_paragraph()\n    p.add_run(title + '：').bold = True\n    p.add_run(content)\n\n# 同行业对比\ndoc.add_heading('🆚 四、同行业对比分析', level=1)\n\ntable4 = doc.add_table(rows=4, cols=6)\ntable4.style = 'Table Grid'\nheaders4 = ['公司', '市盈率', '市净率', '毛利率', '资产负债率', '操作成本']\nfor i, h in enumerate(headers4):\n    table4.rows[0].cells[i].text = h\n    table4.rows[0].cells[i].paragraphs[0].runs[0].bold = True\n\ndata4 = [\n    ['洲际油气', '74.87 倍', '3.93 倍', '56.44%', '28.74%', '6-10 美元/桶'],\n    ['中国石油', '约 12 倍', '0.9 倍', '22.7%', '约 45%', '约 50 美元/桶'],\n    ['中国海油', '约 10 倍', '1.5 倍', '约 50%', '约 30%', '27 美元/桶'],\n]\nfor i, row in enumerate(data4):\n    for j, cell in enumerate(row):\n        table4.rows[i+1].cells[j].text = cell\n\n# 机构观点\ndoc.add_heading('📈 五、机构观点汇总', level=1)\n\ntable5 = doc.add_table(rows=5, cols=5)\ntable5.style = 'Table Grid'\nheaders5 = ['机构', '评级', '目标价', '发布日期', '核心逻辑']\nfor i, h in enumerate(headers5):\n    table5.rows[0].cells[i].text = h\n    table5.rows[0].cells[i].paragraphs[0].runs[0].bold = True\n\ndata5 = [\n    ['申万宏源', '买入', '93.8 元', '2026-01-05', '伊拉克项目投产预期'],\n    ['中信证券', '增持', '88 元', '2025-12-23', '低成本优势 + 氦气稀缺性'],\n    ['中金公司', '跑赢行业', '89.8 元', '2025-12-25', '业绩拐点临近'],\n    ['摩根士丹利', '增持', '85 元', '2025-12-04', '一带一路资产重估'],\n]\nfor i, row in enumerate(data5):\n    for j, cell in enumerate(row):\n        table5.rows[i+1].cells[j].text = cell\n\n# 投资建议\ndoc.add_heading('🎯 六、投资策略建议', level=1)\n\ntable6 = doc.add_table(rows=5, cols=6)\ntable6.style = 'Table Grid'\nheaders6 = ['投资者类型', '建议', '仓位', '入场时机', '止损位', '目标位']\nfor i, h in enumerate(headers6):\n    table6.rows[0].cells[i].text = h\n    table6.rows[0].cells[i].paragraphs[0].runs[0].bold = True\n\ndata6 = [\n    ['保守型', '观望', '0%', '等待 5-6 元', '-', '-'],\n    ['稳健型', '轻仓试探', '5-10%', '分 3 批建仓 (7/6/5 元)', '6 元', '9-10 元'],\n    ['激进型', '波段操作', '10-20%', '当前价轻仓', '6.5 元', '8.5-9 元'],\n    ['长期价值', '战略配置', '20-30%', '分批建仓 (7/6/5 元)', '4.5 元', '12 元 (2027 年)'],\n]\nfor i, row in enumerate(data6):\n    for j, cell in enumerate(row):\n        table6.rows[i+1].cells[j].text = cell\n\n# 关键时间节点\ndoc.add_heading('📅 七、关键时间节点', level=1)\n\ntable7 = doc.add_table(rows=7, cols=3)\ntable7.style = 'Table Grid'\nheaders7 = ['时间', '事件', '影响']\nfor i, h in enumerate(headers7):\n    table7.rows[0].cells[i].text = h\n    table7.rows[0].cells[i].paragraphs[0].runs[0].bold = True\n\ndata7 = [\n    ['2026 年 3 月 9 日', '油价调价窗口', '国内油价或上涨'],\n    ['2026 年 4 月', 'OPEC+ 恢复增产', '油价承压'],\n    ['2026 年 4 月 23 日', '2025 年年报披露', '验证业绩下滑幅度'],\n    ['2026 年下半年', '伊拉克项目启动建设', '关键进展催化'],\n    ['2027 年 5 月', '伊拉克项目投产', '业绩拐点'],\n    ['2027 年', '氦气项目投产', '新增收益 5.25 亿/年'],\n]\nfor i, row in enumerate(data7):\n    for j, cell in enumerate(row):\n        table7.rows[i+1].cells[j].text = cell\n\n# 情景分析\ndoc.add_heading('🎯 八、情景分析与目标价', level=1)\n\ntable8 = doc.add_table(rows=4, cols=6)\ntable8.style = 'Table Grid'\nheaders8 = ['情景', '油价假设', '项目进展', '目标市值', '对应股价', '概率']\nfor i, h in enumerate(headers8):\n    table8.rows[0].cells[i].text = h\n    table8.rows[0].cells[i].paragraphs[0].runs[0].bold = True\n\ndata8 = [\n    ['乐观', '80-90 美元', '伊拉克/氦气按时投产', '250 亿', '12 元', '20%'],\n    ['中性', '65-75 美元', '部分延期', '150 亿', '7.2 元', '50%'],\n    ['悲观', '50-60 美元', '严重延期', '80 亿', '3.8 元', '30%'],\n]\nfor i, row in enumerate(data8):\n    for j, cell in enumerate(row):\n        table8.rows[i+1].cells[j].text = cell\n\n# 最终总结\ndoc.add_heading('💎 九、最终总结', level=1)\ndoc.add_paragraph('洲际油气是一家拥有世界级低成本油气资产的民营公司，债务重整后轻装上阵，但当前股价已严重透支 2027 年预期。')\ndoc.add_paragraph('短期（1-3 月）高风险规避，中期（6-12 月）等待估值回归，长期（2-3 年）若项目顺利投产存在翻倍潜力。')\n\np = doc.add_paragraph()\np.add_run('核心投资逻辑：').bold = True\np.add_run('好资产 ≠ 好股票（在当前价格）。等待好价格 + 项目兑现，才是理性选择。')\n\n# 添加免责声明\ndoc.add_page_break()\ndoc.add_heading('免责声明', level=1)\ndoc.add_paragraph('本报告基于公开信息整理分析，仅供参考，不构成投资建议。股市有风险，投资需谨慎。')\ndoc.add_paragraph('数据来源：东方财富网、同花顺、新浪财经、公司公告等公开渠道。')\ndoc.add_paragraph('报告生成时间：2026 年 3 月 10 日')\n\n# 保存文档\ndoc.save('/root/.openclaw/workspace/files/洲际油气_600759_深度研究报告_20260310.docx')\nprint('文档创建成功：/root/.openclaw/workspace/files/洲际油气_600759_深度研究报告_20260310.docx')\nPYTHON_SCRIPT"}}],"api":"openai-completions","provider":"dashscope","model":"qwen3.5-plus","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773129469478}}
